<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="ApiBaseUrl" value="https://api.example.local/v1" />
    <add key="LogLevel" value="Info" />
    <add key="FeatureXEnabled" value="true" />
    <add key="TelemetryKey" value="CHANGEME" />
  </appSettings>
  <connectionStrings>
    <add name="MainDb" connectionString="Server=localhost;Database=vbapp_staging;User Id=vbuser;Password=CHANGEME;" providerName="System.Data.SqlClient" />
  </connectionStrings>
</configuration>
